{
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 * * * *"
    }
  ],

  "rewrites": [
    { "source": "/api/auth",        "destination": "/api/auth.js" },
    { "source": "/api/assess",      "destination": "/api/assess.js" },
    { "source": "/api/session",     "destination": "/api/session.js" },
    { "source": "/api/logout",      "destination": "/api/logout.js" },
    { "source": "/api/csrf",        "destination": "/api/csrf.js" },
    { "source": "/api/cleanup",     "destination": "/api/cleanup.js" },

    { "source": "/api/oauth/:path*", "destination": "/api/oauth.js" },

    { "source": "/api/mfa",         "destination": "/api/mfa.js" },
    { "source": "/api/password",    "destination": "/api/password.js" },

    { "source": "/",                "destination": "/login.html" },
    { "source": "/login",           "destination": "/login.html" },
    { "source": "/register",        "destination": "/register.html" },
    { "source": "/mfa",             "destination": "/mfa-verify.html" },
    { "source": "/welcome",         "destination": "/welcome.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/reset-password",  "destination": "/reset-password.html" },
    { "source": "/oauth/authorize", "destination": "/authorize.html" },
    { "source": "/developer",       "destination": "/developer-portal.html" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security",         "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy",                   "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",                "value": "geolocation=(), camera=(), microphone=()" },
        { "key": "X-Content-Type-Options",            "value": "nosniff" },
        { "key": "X-Frame-Options",                   "value": "DENY" },
        { "key": "Cross-Origin-Opener-Policy",        "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy",      "value": "same-origin" },
        { "key": "X-Permitted-Cross-Domain-Policies", "value": "none" },
        { "key": "X-DNS-Prefetch-Control",            "value": "off" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests; default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; object-src 'none'; form-action 'self'" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/(|login|register|mfa|welcome|forgot-password|reset-password)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests; default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; object-src 'none'; form-action 'self'" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/oauth/authorize",
      "headers": [
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests; default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; object-src 'none'; form-action 'self'" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/developer",
      "headers": [
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests; default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; object-src 'none'; form-action 'self'" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'none'" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/:path*.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/:path*.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
